# Database (use sqlite for local dev, postgres for production)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/threads_copilot
DATABASE_URL=sqlite+aiosqlite:///./threads_copilot.db

# Threads API (Meta)
THREADS_APP_ID=your_app_id
THREADS_APP_SECRET=your_app_secret
THREADS_REDIRECT_URI=http://localhost:8000/auth/callback

# LLM Provider (OpenRouter, OpenAI, or any OpenAI-compatible API)
LLM_API_KEY=your_api_key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat

# App Security
SECRET_KEY=change-me-to-a-random-string
ADMIN_PASSWORD=changeme

# Optional
LOG_LEVEL=INFO
